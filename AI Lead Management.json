        "text": "=Name: {{ $json['Full Name'] }}\n  Phone: {{ $json['Phone Number'] }}\n  Email: {{ $json.Email }}\n  Interest: {{ $json['What are you interested in?'] }}\n  Budget: {{ $json['What is your budget?'] }}\n  Urgency: {{ $json['How soon do you need this?'] }}\n  Details: {{ $json['Tell us more about your request'] }}",
        "options": {
          "systemMessage": "You are a lead qualification specialist. Your job is to evaluate incoming leads and assign them a temperature score based on the provided data.\n\n  Scoring criteria:\n\n  HOT lead (score: \"hot\"):\n  - Has a specific budget AND high urgency (ASAP or within 1 week)\n  - Provided detailed information about their request\n\n  WARM lead (score: \"warm\"):\n  - Has either a budget OR urgency but not both\n  - Request is somewhat specific\n\n  COLD lead (score: \"cold\"):\n  - No budget mentioned\n  - No urgency or just exploring\n  - Vague or minimal request details\n\n  Return ONLY this JSON, no explanations:\n  {\n    \"score\": \"hot\" | \"warm\" | \"cold\",\n    \"reason\": \"brief explanation in English, max 1 sentence\"\n  }"
        }
      },
