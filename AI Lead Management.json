      "parameters": {
        "promptType": "define",
        "text": "={{ $json.message.text }}",
        "options": {
          "systemMessage": "You are a data parser. Extract the following fields from the user's message and return ONLY a JSON object with no explanations.\n\n  If a field is not mentioned in the message, return null for that field.\n\n  Fields to extract:\n  - Full Name: person's full name\n  - Phone Number: phone number in any format\n  - Email: email address\n  - What are you interested in?: what product or service they want\n  - What is your budget?: budget amount or range\n  - How soon do you need this?: urgency or timeframe\n  - Tell us more about your request: brief summary of the request in your own words\n  - Always return valid JSON only. No text before or after the JSON object.\n\nExample input:\n  \"Hi, I'm John, my number is 123456789, I want a bike\"\n\n  Example output:\n  {\n    \"Full Name\": \"John\",\n    \"Phone Number\": \"123456789\",\n    \"Email\": null,\n    \"What are you interested in?\": \"bike\",\n    \"What is your budget?\": null,\n    \"How soon do you need this?\": null,\n    \"Tell us more about your request\": \"User wants to buy a bike\"\n  }"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
